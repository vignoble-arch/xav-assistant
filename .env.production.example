# Assistant Xavier - configuration serveur
# Copier ce fichier en .env.production sur le VPS puis remplir les valeurs.

APP_DOMAIN=assistant.example.com

ASSISTANT_USER=xavier
ASSISTANT_PASSWORD=change-moi-avec-un-long-mot-de-passe

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://assistant.example.com/auth/google/callback

POSTGRES_PASSWORD=change-moi-avec-un-long-mot-de-passe

AUTO_SYNC_INTERVAL_MINUTES=15

AI_PROVIDER=openai
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-5.4-mini
OPENAI_API_KEY=

BAQIO_BASE_URL=https://app.baqio.com/api/v1
BAQIO_API_KEY=
BAQIO_PASSWORD=
BAQIO_SECRET=
BAQIO_SYNC_MAX_PAGES=10

N8N_BASIC_AUTH_USER=xavier
N8N_BASIC_AUTH_PASSWORD=change-moi-avec-un-long-mot-de-passe
N8N_CADDY_PASSWORD_HASH=hash-caddy-du-mot-de-passe-n8n
N8N_ENCRYPTION_KEY=change-moi-avec-une-cle-longue-de-32-caracteres-minimum
